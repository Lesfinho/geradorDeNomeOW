generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AppUser {
  id        Int         @id @default(autoincrement())
  username  String      @unique @db.VarChar(50)
  pin       String      @db.VarChar(4)
  token     String      @unique @db.VarChar(64)
  createdAt DateTime    @default(now())
  added     NameEntry[] @relation("AddedBy")
  drawn     NameEntry[] @relation("DrawnBy")
  gifs      SharedGif[]

  @@map("app_user")
}

model SharedGif {
  id        Int      @id @default(autoincrement())
  url       String   @unique @db.Text
  addedBy   AppUser  @relation(fields: [addedById], references: [id])
  addedById Int
  createdAt DateTime @default(now())

  @@map("shared_gif")
}

model NameEntry {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(255)
  isUsed    Boolean  @default(false)
  addedBy   AppUser  @relation("AddedBy", fields: [addedById], references: [id])
  addedById Int
  drawnBy   AppUser? @relation("DrawnBy", fields: [drawnById], references: [id])
  drawnById Int?
  createdAt DateTime @default(now())

  @@map("name_entry")
}
